# Example environment for validating the production Compose stack locally.
# Copy to .env.production on the VM and replace every "change-me" value.
# Never commit .env.production or use these placeholder secrets on the VM.

AIS_BACKEND_IMAGE=ais-backend:test
AIS_MIGRATOR_IMAGE=ais-migrator:test
AIS_FRONTEND_IMAGE=ais-web:test
POSTGRES_IMAGE=postgis/postgis:16-3.4
REDIS_IMAGE=redis:7-alpine
PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
GRAFANA_IMAGE=grafana/grafana:11.3.1

NGINX_HTTP_PORT=80

POSTGRES_USER=ais
# Required in production. Generate a strong unique value for the VM.
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ais

LOG_LEVEL=info
# Required in production. Phase 4 will block /admin at Nginx, but the API still
# runs AdminModule and should fail closed with a strong token configured.
ADMIN_TOKEN=change-me

# Empty disables live ingestion for local production-stack validation.
# Set to "aisstream" and provide AISSTREAM_API_KEY for live AISStream ingestion.
AIS_PROVIDERS=
AISSTREAM_API_KEY=

METRICS_ENABLED=true

HISTORY_RETENTION_DAYS=7
HISTORY_PRECREATE_DAYS=7
HISTORY_PARTITION_MAINTENANCE_ENABLED=true

WS_SEND_QUEUE_MAX=256
WS_BUFFERED_AMOUNT_LIMIT_BYTES=1048576
WS_HEARTBEAT_INTERVAL_MS=30000

GRAFANA_ADMIN_USER=admin
# Required in production. Generate a strong unique value for the VM.
GRAFANA_ADMIN_PASSWORD=change-me
